# Copy this file to ".env" and fill in your keys.
# Both have generous free tiers.

# Cesium ion access token — https://ion.cesium.com/tokens
VITE_CESIUM_ION_TOKEN=

# Google Maps Platform API key with the "Map Tiles API" enabled —
# https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_MAPS_KEY=

# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Browserbase — https://www.browserbase.com/settings (API key + project ID)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Deepgram API key for narration text-to-speech (optional — app stays text-only without it)
# https://console.deepgram.com/
VITE_DEEPGRAM_API_KEY=

# Backend (server/) for the neighborhood Q&A feature
PORT=8787
VITE_API_BASE_URL=http://localhost:8787
